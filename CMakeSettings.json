{
  "configurations": [
    {
      "name": "N-Gage",
      "generator": "Ninja",
      "configurationType": "Release",
      "inheritEnvironments": [ "msvc_x64_x64" ],
      "buildRoot": "${projectDir}\\out\\build\\${name}",
      "installRoot": "${projectDir}\\out\\install\\${name}",
      "cmakeCommandArgs": "-DCMAKE_PREFIX_PATH=${env.NGAGESDK}/sdk/extras/lib/cmake",
      "buildCommandArgs": "",
      "ctestCommandArgs": "",
      "variables": [
        {
          "name": "CMAKE_TOOLCHAIN_FILE",
          "value": "${env.NGAGESDK}/cmake/ngage-toolchain.cmake",
          "type": "FILEPATH"
        }
      ]
    },
    {
      "name": "Emscripten",
      "generator": "Ninja",
      "configurationType": "Release",
      "buildRoot": "${projectDir}/out/build/${name}",
      "installRoot": "${projectDir}/out/install/${name}",
      "cmakeCommandArgs": "-DCMAKE_TOOLCHAIN_FILE=\"${env.EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake\"",
      "buildCommandArgs": "",
      "ctestCommandArgs": "",
      "inheritEnvironments": [ "emscripten" ],
      "variables": [
        {
          "name": "CMAKE_INTERPROCEDURAL_OPTIMIZATION",
          "value": "ON",
          "type": "STRING"
        },
        {
          "name": "EMSCRIPTEN_KEEP_ASSERTIONS",
          "value": "OFF",
          "type": "STRING"
        }
      ]
    },
    {
      "name": "x86-Release",
      "generator": "Ninja",
      "configurationType": "RelWithDebInfo",
      "buildRoot": "${projectDir}\\out\\build\\${name}",
      "installRoot": "${projectDir}\\out\\install\\${name}",
      "cmakeCommandArgs": "",
      "buildCommandArgs": "",
      "ctestCommandArgs": "",
      "inheritEnvironments": [ "msvc_x86" ]
    },
    {
      "name": "x86-Debug",
      "generator": "Ninja",
      "configurationType": "Debug",
      "buildRoot": "${projectDir}\\out\\build\\${name}",
      "installRoot": "${projectDir}\\out\\install\\${name}",
      "cmakeCommandArgs": "",
      "buildCommandArgs": "",
      "ctestCommandArgs": "",
      "inheritEnvironments": [ "msvc_x86" ],
      "variables": [
        {
          "name": "BUILD_TESTS",
          "value": "true",
          "type": "BOOL"
        }
      ]
    },
    {
      "name": "DOS",
      "generator": "Ninja",
      "configurationType": "Release",
      "buildRoot": "${projectDir}\\out\\build\\${name}",
      "installRoot": "${projectDir}\\out\\install\\${name}",
      "cmakeCommandArgs": "-DCMAKE_TOOLCHAIN_FILE=${projectDir}/cmake/i586-pc-msdosdjgpp.cmake",
      "buildCommandArgs": "-v",
      "ctestCommandArgs": "",
      "inheritEnvironments": [ "mingw_64" ],
      "environments": [
        {
          "BIN_ROOT": "${env.DJGPP_DIR}/bin",
          "FLAVOR": "x86_64-w64-mingw32",
          "TOOLSET_VERSION": "9.1.0",
          "PATH": "${env.DJGPP_DIR}/bin;${env.DJGPP_DIR}/../usr/local/bin;${env.DJGPP_DIR}/../usr/bin;${env.DJGPP_DIR}/../bin;${env.PATH}",
          "INCLUDE": "${env.INCLUDE};${env.DJGPP_DIR}/include/c++/${env.TOOLSET_VERSION};${env.DJGPP_DIR}/include/c++/${env.TOOLSET_VERSION}/tr1;${env.DJGPP_DIR}/include/c++/${env.TOOLSET_VERSION}/${env.FLAVOR}",
          "environment": "mingw_64"
        }
      ],
      "intelliSenseMode": "linux-gcc-x64"
    }
  ]
}